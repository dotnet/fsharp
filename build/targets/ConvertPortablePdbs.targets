<Project>

  <ItemGroup>
    <PackageReference Include="Microsoft.DiaSymReader.Pdb2Pdb" Version="$(MicrosoftDiaSymReaderPdb2PdbPackageVersion)" />
  </ItemGroup>

  <Target Name="ConvertPortablePdbs"
          AfterTargets="AfterBuild"
          Condition="Exists('$(TargetPath)') AND ('$(DebugType)' == 'portable' OR '$(DebugType)' == 'embedded')">
    <PropertyGroup>
      <ConvertedPdbsDirectory>$(FinalOutputPath)\ConvertedPdbs</ConvertedPdbsDirectory>
      <PdbConverterExe>$(NuGetPackageRoot)Microsoft.DiaSymReader.Pdb2Pdb\$(MicrosoftDiaSymReaderPdb2PdbPackageVersion)\tools\Pdb2Pdb.exe</PdbConverterExe>
      <!-- Block 5.7 Patch D: Pdb2Pdb 1.1.0-beta2-20527-01 (S5.5 remediation pin) does not accept
           legacy /verbose flag, and rejects /srcsvrvar when /sourcelink is not specified.
           Strip both to keep this PDB conversion step working on the modern Pdb2Pdb. -->
      <PdbConverterArgs>"$(TargetPath)" /out "$(ConvertedPdbsDirectory)\$(TargetName).pdb"</PdbConverterArgs>
    </PropertyGroup>

    <MakeDir Directories="$(ConvertedPdbsDirectory)" />
    <!-- Block 9b: Pdb2Pdb 1.1.0-beta2-20527-01 fails "Unsupported format version: 0.0" on the
         PDBs several 15.9 projects emit (e.g. the proto compiler, FSharp.Core). Portable->Windows
         PDB conversion is only needed for symbol-server publishing/indexing, NOT for the build
         output or the VS insertion to function. ContinueOnError keeps a conversion failure from
         failing the build (it degrades to a warning). A proper Pdb2Pdb version bump can restore
         full symbol conversion later without blocking the build green. -->
    <Exec Command='"$(PdbConverterExe)" $(PdbConverterArgs)' ContinueOnError="true" />
  </Target>

</Project>
