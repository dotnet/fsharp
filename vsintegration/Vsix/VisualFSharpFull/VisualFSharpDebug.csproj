<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <ExtensionInstallationFolder>Microsoft\FSharp</ExtensionInstallationFolder>
    <PackageTargetFallback>netcoreapp1.0</PackageTargetFallback>
    <IsShipping>true</IsShipping>
    <DependencyTargetFramework>net472</DependencyTargetFramework>
    <DeployExtension>true</DeployExtension>    
    <UseSharedCompilation>false</UseSharedCompilation>
    <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
  </PropertyGroup>

  <Import Project="VisualFSharp.Core.targets" />

  <Target Name="_GenerateLanguageList">
    <CreateItem Include="$(XlfLanguages)">
      <Output TaskParameter="Include" ItemName="_XlfLanguages" />
    </CreateItem>
  </Target>

  <Target Name="_ToolsDirFiles" BeforeTargets="CopyFilesToOutputDirectory" DependsOnTargets="_GenerateLanguageList">
    <ItemGroup>
      <Content Include="$(ArtifactsBinDir)/fsc/$(Configuration)/net472/**/%(_XlfLanguages.Identity)/*">
        <VSixSubPath>Tools/%(_XlfLanguages.Identity)</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fsi/$(Configuration)/net472/**/%(_XlfLanguages.Identity)/*">
        <VSixSubPath>Tools/%(_XlfLanguages.Identity)</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fsiAnyCpu/$(Configuration)/net472/**/%(_XlfLanguages.Identity)/*">
        <VSixSubPath>Tools/%(_XlfLanguages.Identity)</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fscAnyCpu/$(Configuration)/net472/**/%(_XlfLanguages.Identity)/*">
        <VSixSubPath>Tools/%(_XlfLanguages.Identity)</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fscArm64/$(Configuration)/net472/**/%(_XlfLanguages.Identity)/*">
        <VSixSubPath>Tools/%(_XlfLanguages.Identity)</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fsiArm64/$(Configuration)/net472/**/%(_XlfLanguages.Identity)/*">
        <VSixSubPath>Tools/%(_XlfLanguages.Identity)</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fsc/$(Configuration)/net472/*">
        <VSixSubPath>Tools</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fscAnyCPU/$(Configuration)/net472/*">
        <VSixSubPath>Tools</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fscArm64/$(Configuration)/net472/*">
        <VSixSubPath>Tools</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fsi/$(Configuration)/net472/*">
        <VSixSubPath>Tools</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fsiAnyCPU/$(Configuration)/net472/*">
        <VSixSubPath>Tools</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>

      <Content Include="$(ArtifactsBinDir)/fsiArm64/$(Configuration)/net472/*">
        <VSixSubPath>Tools</VSixSubPath>
        <IncludeInVSIX>true</IncludeInVSIX>
      </Content>
    </ItemGroup>
  </Target>

  <!--
    Generate a catalog (.cat) file covering non-PE content files (XML templates)
    so the VS signing scan does not flag them as unsigned.
    Only runs on Windows (makecat.exe is a Windows SDK tool).
  -->
  <Target Name="GenerateCatalogFiles" AfterTargets="CreateVsixContainer"
          Condition="$([MSBuild]::IsOSPlatform('Windows')) and Exists('$(TargetVsixContainer)')">
    <PropertyGroup>
      <_ContentRoot>$(TargetVsixContainerIntermediateOutputPath)</_ContentRoot>
      <_CatOutputPath>$(TargetVsixContainerIntermediateOutputPath)FSharpDebugContent.cat</_CatOutputPath>
      <_ErrorFlag Condition="'$(ContinuousIntegrationBuild)' == 'true' or '$(OfficialBuild)' == 'true'">-ErrorIfMakecatNotFound</_ErrorFlag>
    </PropertyGroup>

    <Exec Command="powershell.exe -NoProfile -ExecutionPolicy Bypass -Command &quot;&amp; '$(RepoRoot)eng\generate-catalog.ps1' -RootPath '$(_ContentRoot)' -CatOutputPath '$(_CatOutputPath)' -Filter '*.xml' -RunMakecat -WindowsSdkDir '$(WindowsSdkDir)' $(_ErrorFlag)&quot;"
          StandardOutputImportance="High"
          IgnoreExitCode="true"
          Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
  </Target>
</Project>
