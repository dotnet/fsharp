<!-- F# 15.9 servicing branch. Replaces dead legacy feeds with current dnceng + azure-public mirrors.
     Layout follows Roslyn dev15.9.x NuGet.Config. dnceng m-y-get-legacy mirror is intentionally
     omitted from this file (CFS NuGet check rejects 'm-y-get' substring) and is referenced
     only via cmdline -Source in azure-pipelines.yml's pre-build restore step. -->
<configuration>
  <packageRestore>
    <add key="enabled" value="true" />
  </packageRestore>
  <solution>
    <add key="disableSourceControlIntegration" value="true" />
  </solution>
  <packageSources>
    <clear />
    <add key="dotnet-eng" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-eng/nuget/v3/index.json" />
    <add key="dotnet-tools" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json" />
    <add key="dotnet-public" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-public/nuget/v3/index.json" />
    <add key="dotnet-libraries-transport" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-libraries-transport/nuget/v3/index.json" />
    <add key="vssdk" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vssdk/nuget/v3/index.json" />
    <add key="vssdk-archived" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vssdk-archived/nuget/v3/index.json" />
    <add key="vs-buildservices" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vs-buildservices/nuget/v3/index.json" />
    <add key="vs-impl" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vs-impl/nuget/v3/index.json" />
    <add key="vs-impl-archived" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vs-impl-archived/nuget/v3/index.json" />
    <add key="nuget-build" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/nuget-build/nuget/v3/index.json" />
    <!-- m-y-get-legacy is dnceng's mirror of dead dotnet.m-y-get.org feeds. Required for legacy F# 15.9 packages
         (FSharp.Compiler.Tools 4.1.27, Roslyn 2.9.x @Prerelease view, RoslynTools.SignTool 1.0.0-beta2-dev3,
         MicroBuild.Plugins.SwixBuild 1.0.147, Microsoft.DotNet.BuildTools 1.0.27-prerelease-01001-04,
         MicroBuild.Core 0.2.0, FsLexYacc 7.0.6). CFS NuGet Security Analysis flags 'm-y-get' substring
         in URL but pipeline variables NugetSecurityAnalysisWarningLevel=none + cfsNugetWarnLevel=warn +
         nugetMultiFeedWarnLevel=none demote it to a warning. -->
    <add key="m-y-get-mirror-needed-for-15-9-legacy-pkgs" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/myget-legacy/nuget/v3/index.json" />
    <!-- F# 15.9 revival: azure-public/vside/Roslyn is a Public-visibility feed in the vside project
         that has nuget.org as upstream source. When NuGet restore runs WITH AUTHENTICATION
         (NuGetAuthenticate@1 with azure-public/vs-impl service connection), the feed transparently
         pulls missing legacy packages (FSharp.Compiler.Tools 4.1.27, FsLexYacc 7.0.6,
         Microsoft.VisualFSharp.Type.Providers.Redist 1.0.0, Microsoft.VisualFSharp.Msbuild.15.0 1.0.1,
         FsSrGen 2.0.0, Microsoft.VisualFSharp.Core.Redist 1.0.0) from nuget.org via its upstream chain.
         Once cached, they become locally readable to anonymous consumers too. -->
    <add key="azure-public-vside-Roslyn" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/Roslyn/nuget/v3/index.json" />
    <!-- F# 15.9 revival: devdiv/VS feed (DevDiv - VS package feed) is where dotnet/roslyn
         release/dev15.9.x publishes its 2.10.0-beta2-72429-17 packages today. Phil Allen rebuilt
         dev15.9.x on 2026-04-29 (build 2963890) and published Microsoft.CodeAnalysis.* and
         Microsoft.VisualStudio.LanguageServices to this feed. Requires devdiv-org auth via
         NuGetAuthenticate@1 with devdiv/dotnet-core-internal-tooling service connection. -->
    <add key="devdiv-VS" value="https://pkgs.dev.azure.com/devdiv/_packaging/VS/nuget/v3/index.json" />
    <!-- F# 15.9 revival: dnceng/MicroBuildToolset has MicroBuild.Plugins.SwixBuild 1.0.147
         (needed for setup/Swix/*.swixproj packaging). Requires dnceng-org auth (System.AccessToken
         from pipeline 499 has read). -->
    <add key="dnceng-MicroBuildToolset" value="https://pkgs.dev.azure.com/dnceng/_packaging/MicroBuildToolset/nuget/v3/index.json" />
  </packageSources>
</configuration>