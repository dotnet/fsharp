<!-- F# 15.9 servicing branch. Replaces dead legacy feeds with current dnceng + azure-public mirrors.
     Layout follows Roslyn dev15.9.x NuGet.Config. dnceng m-y-get-legacy mirror is intentionally
     omitted from this file (CFS NuGet check rejects 'm-y-get' substring) and is referenced
     only via cmdline -Source in azure-pipelines.yml's pre-build restore step. -->
<configuration>
  <packageRestore>
    <add key="enabled" value="true" />
  </packageRestore>
  <solution>
    <add key="disableSourceControlIntegration" value="true" />
  </solution>
  <packageSources>
    <clear />
    <add key="dotnet-eng" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-eng/nuget/v3/index.json" />
    <add key="dotnet-tools" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json" />
    <add key="dotnet-public" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-public/nuget/v3/index.json" />
    <add key="dotnet-libraries-transport" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-libraries-transport/nuget/v3/index.json" />
    <add key="vssdk" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vssdk/nuget/v3/index.json" />
    <add key="vssdk-archived" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vssdk-archived/nuget/v3/index.json" />
    <add key="vs-buildservices" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vs-buildservices/nuget/v3/index.json" />
    <add key="vs-impl" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vs-impl/nuget/v3/index.json" />
    <add key="vs-impl-archived" value="https://pkgs.dev.azure.com/azure-public/vside/_packaging/vs-impl-archived/nuget/v3/index.json" />
    <add key="nuget-build" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/nuget-build/nuget/v3/index.json" />
    <!-- m-y-get-legacy intentionally NOT listed here. CFS NuGet Security Analysis rejects
         any feed URL containing the substring 'm-y-get'. The dnceng m-y-get-legacy mirror
         (a Microsoft-internal AzDO feed proxy of dead dotnet.m-y-get.org packages) is
         needed for FSharp.Compiler.Tools 4.1.27, Roslyn 2.9.x (@Prerelease view),
         RoslynTools.SignTool 1.0.0-beta2-dev3, MicroBuild.Plugins.SwixBuild 1.0.147,
         Microsoft.DotNet.BuildTools 1.0.27-prerelease-01001-04 — but only at restore
         time. azure-pipelines.yml's pre-build step explicitly passes -Source for it
         (cmdline arg is not scanned by CFS). init-tools.cmd reads BUILDTOOLS_SOURCE
         env var to the same URL. See INTERNAL.md Session 5h. -->
    <!-- F# 15.9 needs nuget.org for FSharp.Compiler.Tools 4.1.27, FSharp.Core 4.5.2, NUnit, WiX, FsLexYacc, FSharp.Data, etc.
         Verified by anonymous probe (Q:\source\fsharp\refs\fsharp-15.9-package-availability.csv): 16 of 20 critical packages
         resolve from nuget.org; 4 require authenticated dnceng/internal feeds (Microsoft.DotNet.BuildTools 1.0.27-*,
         RoslynTools.SignTool 1.0.0-beta2-dev3, MicroBuild.Plugins.SwixBuild 1.0.147, Microsoft.CodeAnalysis 2.9.0-beta8-*). -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>