<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <!-- Files are deliberately in WRONG dependency order:
       FileC depends on FileB and FileA
       FileB depends on FileA
       But FileC is listed first, FileA last.

       With standard F# compilation, this WILL FAIL.
       With our modified compiler using ‑‑file-order-auto+, it should succeed. -->
  <ItemGroup>
    <Compile Include="FileC.fs" />
    <Compile Include="FileB.fs" />
    <Compile Include="FileA.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

</Project>
