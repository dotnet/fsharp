<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>
  <!-- Wrong order: Main and Consumer (which use Types) listed before Types.fsi/Types.fs.
       Auto-order must place Types.fsi+Types.fs before consumers, keeping the pair adjacent. -->
  <ItemGroup>
    <Compile Include="Main.fs" />
    <Compile Include="Consumer.fs" />
    <Compile Include="Types.fsi" />
    <Compile Include="Types.fs" />
  </ItemGroup>
</Project>
