<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="FSharp.Compiler.Split.props" />

  <PropertyGroup>
    <AssemblyName>FSharp.Compiler.CodeGen</AssemblyName>
  </PropertyGroup>


  <ItemGroup>
    <!-- CodeGen source files in order from main fsproj -->
    <Compile Include="..\CodeGen\IlxGenSupport.fsi">
      <Link>CodeGen\IlxGenSupport.fsi</Link>
    </Compile>
    <Compile Include="..\CodeGen\IlxGenSupport.fs">
      <Link>CodeGen\IlxGenSupport.fs</Link>
    </Compile>
    <Compile Include="..\CodeGen\EraseClosures.fsi">
      <Link>CodeGen\EraseClosures.fsi</Link>
    </Compile>
    <Compile Include="..\CodeGen\EraseClosures.fs">
      <Link>CodeGen\EraseClosures.fs</Link>
    </Compile>
    <Compile Include="..\CodeGen\EraseUnions.fsi">
      <Link>CodeGen\EraseUnions.fsi</Link>
    </Compile>
    <Compile Include="..\CodeGen\EraseUnions.fs">
      <Link>CodeGen\EraseUnions.fs</Link>
    </Compile>
    <Compile Include="..\CodeGen\IlxGen.fsi">
      <Link>CodeGen\IlxGen.fsi</Link>
    </Compile>
    <Compile Include="..\CodeGen\IlxGen.fs">
      <Link>CodeGen\IlxGen.fs</Link>
    </Compile>
  </ItemGroup>

  <!-- InternalsVisibleTo for downstream split projects -->
  <ItemGroup>
    <InternalsVisibleTo Include="FSharp.Compiler.Driver" />
    <InternalsVisibleTo Include="FSharp.Compiler.Interactive" />
    <InternalsVisibleTo Include="FSharp.Compiler.Service" />
  </ItemGroup>

  <!-- Project references -->
  <ItemGroup>
    <ProjectReference Include="FSharp.Compiler.Utilities.fsproj" />
    <ProjectReference Include="FSharp.Compiler.AbstractIL.fsproj" />
    <ProjectReference Include="FSharp.Compiler.SyntaxTree.fsproj" />
    <ProjectReference Include="FSharp.Compiler.TypedTree.fsproj" />
    <ProjectReference Include="FSharp.Compiler.Checking.fsproj" />
    <ProjectReference Include="FSharp.Compiler.Optimize.fsproj" />
  </ItemGroup>

  <!-- Package references for netstandard2.0 -->
  <ItemGroup Condition="'$(TargetFrameworkIdentifier)' != '.NETCoreApp'">
    <PackageReference Include="System.Reflection.Metadata" Version="$(SystemReflectionMetadataVersion)" />
  </ItemGroup>

</Project>
