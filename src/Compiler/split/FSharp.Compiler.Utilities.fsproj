<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="FSharp.Compiler.Split.props" />

  <PropertyGroup>
    <AssemblyName>FSharp.Compiler.Utilities</AssemblyName>
  </PropertyGroup>

  <!-- InternalsVisibleTo for downstream split projects -->
  <ItemGroup>
    <InternalsVisibleTo Include="FSharp.Compiler.AbstractIL" />
    <InternalsVisibleTo Include="FSharp.Compiler.SyntaxTree" />
    <InternalsVisibleTo Include="FSharp.Compiler.TypedTree" />
    <InternalsVisibleTo Include="FSharp.Compiler.Checking" />
    <InternalsVisibleTo Include="FSharp.Compiler.Optimize" />
    <InternalsVisibleTo Include="FSharp.Compiler.CodeGen" />
    <InternalsVisibleTo Include="FSharp.Compiler.Driver" />
    <InternalsVisibleTo Include="FSharp.Compiler.Interactive" />
    <InternalsVisibleTo Include="FSharp.Compiler.Service" />
  </ItemGroup>

  <ItemGroup>
    <!-- Embedded resources -->
    <EmbeddedText Include="..\FSComp.txt">
      <Link>FSComp.txt</Link>
    </EmbeddedText>
    <EmbeddedText Include="..\Facilities\UtilsStrings.txt">
      <Link>UtilsStrings.txt</Link>
    </EmbeddedText>
    <EmbeddedResource Include="..\FSStrings.resx">
      <Link>FSStrings.resx</Link>
      <LogicalName>FSStrings.resources</LogicalName>
    </EmbeddedResource>

    <!-- NullnessShims must come first -->
    <Compile Include="..\Utilities\NullnessShims.fs">
      <Link>Utilities\NullnessShims.fs</Link>
    </Compile>

    <!-- Utilities files -->
    <Compile Include="..\Utilities\Activity.fsi">
      <Link>Utilities\Activity.fsi</Link>
    </Compile>
