    </EmbeddedText>
    <EmbeddedResource Include="..\FSStrings.resx">
      <Link>FSStrings.resx</Link>
      <LogicalName>FSStrings.resources</LogicalName>
    </EmbeddedResource>

    <!-- NullnessShims must come first -->
    <Compile Include="..\Utilities\NullnessShims.fs">
